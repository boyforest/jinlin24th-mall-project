# Copy to .env on the server and change every secret before first deploy.

MYSQL_ROOT_PASSWORD=change-this-mysql-root-password
MYSQL_DATABASE=jinlin24th
MYSQL_HOST_PORT=13306

REDIS_PASSWORD=change-this-redis-password
REDIS_DATABASE=1
REDIS_HOST_PORT=16379

# If Baota/Nginx already uses port 80, change this to 8080 and reverse proxy to 127.0.0.1:8080.
ADMIN_WEB_HOST_PORT=80
BACKEND_HOST_PORT=7878

SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-bytes
JAVA_OPTS="-Xms256m -Xmx512m"

# 必填：管理后台实际访问地址，多个域名用英文逗号分隔
# 例：https://admin.jinlin24th.com,https://www.jinlin24th.com
# 警告：不要使用 * ，否则任何网站都能跨域携带 cookie 访问你的接口
CORS_ALLOWED_ORIGINS=https://your-domain.com

# 必填：服务器公网访问地址，用于生成上传图片的完整 URL
# 例：http://8.130.134.79 或 https://api.jinlin24th.cn
APP_PUBLIC_URL=http://your-server-ip

WX_MINIAPP_APPID=
WX_MINIAPP_SECRET=

WX_PAY_ENABLED=false
WX_PAY_MCH_ID=
WX_PAY_API_V3_KEY=
WX_PAY_SERIAL_NO=
WX_PAY_PRIVATE_KEY_PATH=
WX_PAY_CERTIFICATE_PATH=
WX_PAY_NOTIFY_URL=
WX_PAY_REFUND_NOTIFY_URL=

ROCKETMQ_ENABLED=false
